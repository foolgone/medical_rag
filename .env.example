# 数据库配置
DATABASE_URL=postgresql://myuser:mypassword@localhost:5432/medical_rag

# Ollama配置
OLLAMA_BASE_URL=http://localhost:11434
EMBEDDING_MODEL=bge-m3:latest
LLM_MODEL=qwen2.5:7b

# RAG配置
CHUNK_SIZE=500
CHUNK_OVERLAP=50
TOP_K=5

# API配置
API_HOST=0.0.0.0
API_PORT=8000
DEBUG=true

# 日志配置
LOG_LEVEL=INFO

# 文件上传配置
MAX_UPLOAD_SIZE=52428800
ALLOWED_EXTENSIONS=pdf,docx,txt
